# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/template_app

# Better Auth (required)
# Generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-this-with-a-32-character-secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Google Generative AI (optional — used if the app calls Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=

# S3-compatible storage (optional — e.g. MinIO or AWS S3)
# For MinIO, keep S3_FORCE_PATH_STYLE=true
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
