{
  "name": "nextjs-template",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "auth:generate": "better-auth generate --yes --config ./lib/auth.ts --output ./better-auth.schema.sql",
    "auth:info": "better-auth info --config ./lib/auth.ts",
    "auth:migrate": "better-auth migrate --yes --config ./lib/auth.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@base-ui/react": "^1.3.0",
    "@remixicon/react": "^4.9.0",
    "ai": "^6.0.168",
    "better-auth": "^1.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
